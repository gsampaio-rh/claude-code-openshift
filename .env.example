# ============================================================================
# AgentOps Platform — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your cluster-specific values.
#   cp .env.example .env
#
# This file is loaded by all deployment scripts.
# .env is gitignored — never commit credentials.
# ============================================================================

# --- OpenShift Cluster ---
OPENSHIFT_API=https://api.ocp.example.com:6443

# --- Namespaces ---
NAMESPACE_INFERENCE=inference
NAMESPACE_AGENT_SANDBOXES=agent-sandboxes
NAMESPACE_CODER=coder
NAMESPACE_AGENTOPS=agentops
NAMESPACE_MCP_GATEWAY=mcp-gateway
NAMESPACE_OBSERVABILITY=observability
NAMESPACE_CICD=cicd

# --- Model Serving (vLLM) ---
MODEL_NAME=qwen25-14b
MODEL_HF_URI=hf://RedHatAI/Qwen2.5-14B-Instruct-FP8-dynamic
MAX_MODEL_LEN=32768
TOOL_CALL_PARSER=hermes
GPU_MEMORY_UTILIZATION=0.90
GPU_COUNT=1
VLLM_IMAGE=vllm/vllm-openai:v0.19.0

# --- Guardrails ---
ORCHESTRATOR_REPLICAS=1

# --- Claude Code Agent Image ---
CLAUDE_CODE_AGENT_IMAGE=image-registry.openshift-image-registry.svc:5000/agent-sandboxes/claude-code-agent:latest
CLAUDE_CODE_MAX_OUTPUT_TOKENS=8192
MAX_THINKING_TOKENS=0

# --- Observability ---
OTEL_COLLECTOR_IMAGE=ghcr.io/open-telemetry/opentelemetry-collector-releases/opentelemetry-collector-contrib:0.120.0
MLFLOW_IMAGE=ghcr.io/mlflow/mlflow:v3.10.1
MLFLOW_STORAGE_SIZE=10Gi
GRAFANA_IMAGE=grafana/grafana:11.5.2
GRAFANA_ADMIN_PASSWORD=agentops

# --- Timeouts ---
MODEL_READY_TIMEOUT=600s
ORCHESTRATOR_READY_TIMEOUT=300s
OBSERVABILITY_READY_TIMEOUT=300s
