      "targets": [{ "expr": "sum(claude_code_token_usage_tokens_total{type=\"cacheCreation\", job=\"otel-collector\"})", "legendFormat": "cacheCreation" }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
