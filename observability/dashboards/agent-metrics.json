      "targets": [{
        "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\",job=\"otel-collector\"}[5m])) / (sum(rate(claude_code_token_usage_tokens_total{type=\"input\",job=\"otel-collector\"}[5m])) + sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\",job=\"otel-collector\"}[5m])))",
        "legendFormat": "cache hit rate"
      }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },
    {
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
