      "id": 43,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Avg LLM Call Duration",
      "description": "Average LLM span duration",
      "type": "stat",
      "targets": [{
        "expr": "sum(mlflow_trace_span_duration_milliseconds_sum{span_type=\"LLM\"}) / sum(mlflow_trace_span_duration_milliseconds_count{span_type=\"LLM\"})",
