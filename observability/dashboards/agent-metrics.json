      }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },
    {
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "dark-red" }, "unit": "short", "decimals": 1 } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 14 },
      "id": 35,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
