      "type": "stat",
      "targets": [{
        "expr": "sum(claude_code_token_usage_tokens_total{type=\"output\",job=\"otel-collector\"}) / sum(claude_code_token_usage_tokens_total{type=\"input\",job=\"otel-collector\"})",
        "legendFormat": "ratio"
      }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },
    {
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "semi-dark-purple" }, "unit": "short", "decimals": 1 } },
