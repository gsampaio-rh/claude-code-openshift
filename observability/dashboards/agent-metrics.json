      "targets": [{ "expr": "sum(claude_code_cost_usage_USD_total{job=\"otel-collector\"})", "legendFormat": "total cost (USD)" }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },

