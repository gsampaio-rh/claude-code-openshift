        "expr": "sum(mlflow_trace_span_duration_milliseconds_count{root=\"true\"})",
        "legendFormat": "traces"
      }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },
    {
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "semi-dark-green" }, "unit": "short", "decimals": 0 } },
