      "type": "stat",
      "targets": [{
        "expr": "sum(claude_code_token_usage_tokens_total{job=\"otel-collector\"}) / count(count by (session_id) (claude_code_session_count_total{job=\"otel-collector\"}))",
        "legendFormat": "tokens/session"
      }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },
    {
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "semi-dark-orange" }, "unit": "short", "decimals": 2 } },
