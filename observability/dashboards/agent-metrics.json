      "id": 31,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Avg Cost / Session",
      "type": "stat",
      "targets": [{
        "expr": "sum(claude_code_cost_usage_USD_total{job=\"otel-collector\"}) / count(count by (session_id) (claude_code_session_count_total{job=\"otel-collector\"}))",
        "legendFormat": "cost/session"
      }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },
    {
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "semi-dark-blue" }, "unit": "short", "decimals": 0 } },
