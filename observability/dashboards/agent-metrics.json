      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Input Tokens",
      "type": "stat",
      "targets": [{ "expr": "sum(claude_code_token_usage_tokens_total{type=\"input\", job=\"otel-collector\"})", "legendFormat": "input" }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
