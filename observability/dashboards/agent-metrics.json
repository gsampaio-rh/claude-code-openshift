      "type": "stat",
      "targets": [{
        "expr": "sum(claude_code_commit_count_total{job=\"otel-collector\"}) / count(count by (session_id) (claude_code_session_count_total{job=\"otel-collector\"}))",
        "legendFormat": "commits/session"
      }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },
    {
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
