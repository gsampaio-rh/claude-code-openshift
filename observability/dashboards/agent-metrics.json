      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },
    {
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 8,
      "title": "Tokens by Model",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total{job=\"otel-collector\"}[5m]))", "legendFormat": "{{model}}" }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 150,
      "title": "Derived Efficiency Metrics",
      "type": "row"
    },
    {
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "semi-dark-green" }, "unit": "percentunit", "decimals": 1 } },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 14 },
      "id": 30,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Cache Hit Rate",
      "description": "cacheRead / (input + cacheRead)",
      "type": "stat",
      "targets": [{
        "expr": "sum(claude_code_token_usage_tokens_total{type=\"cacheRead\",job=\"otel-collector\"}) / (sum(claude_code_token_usage_tokens_total{type=\"input\",job=\"otel-collector\"}) + sum(claude_code_token_usage_tokens_total{type=\"cacheRead\",job=\"otel-collector\"}))",
        "legendFormat": "hit rate"
      }],
      "datasource": { "type": "prometheus", "uid": "PBA87B4870F3F41AD" }
    },
    {
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "semi-dark-yellow" }, "unit": "currencyUSD", "decimals": 4 } },
