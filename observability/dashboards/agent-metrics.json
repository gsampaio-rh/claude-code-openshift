{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Spans Received / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(calls_total[1m])",
          "legendFormat": "{{service_name}} — {{span_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Trace Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(duration_milliseconds_bucket[5m])) by (le, service_name))",
          "legendFormat": "p50 — {{service_name}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(duration_milliseconds_bucket[5m])) by (le, service_name))",
          "legendFormat": "p95 — {{service_name}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(duration_milliseconds_bucket[5m])) by (le, service_name))",
          "legendFormat": "p99 — {{service_name}}",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Active Services",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "expr": "count(count by (service_name) (calls_total))",
          "legendFormat": "Services",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Spans / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(calls_total[1m]))",
          "legendFormat": "Spans/min",
          "refId": "A"
        }
      ]
    },
    {
      "title": "OTEL Collector — Exported Spans / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_OTEL_INTERNAL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 30 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(otelcol_exporter_sent_spans_total[1m])",
          "legendFormat": "{{exporter}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "OTEL Collector — Dropped Spans / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_OTEL_INTERNAL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 30 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(otelcol_exporter_send_failed_spans_total[1m])",
          "legendFormat": "{{exporter}} (failed)",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["agentops", "otel", "agents"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 2
      },
      {
        "name": "DS_OTEL_INTERNAL",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 2
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AgentOps — Agent Metrics",
  "uid": "agentops-agent-metrics",
  "version": 1
}
